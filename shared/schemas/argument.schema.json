{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Argument",
  "description": "A philosophical argument with premises, conclusion, and inference type.",
  "type": "object",
  "properties": {
    "argument_id": {
      "type": "string",
      "pattern": "^phil:A[0-9]+$"
    },
    "premises": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "role": { "type": "string", "enum": ["major", "minor", "auxiliary", "hidden"] }
        },
        "required": ["text"]
      }
    },
    "conclusion": {
      "type": "object",
      "properties": {
        "text": { "type": "string" }
      },
      "required": ["text"]
    },
    "inference_type": {
      "type": "string",
      "enum": ["deductive", "inductive", "abductive", "transcendental", "dialectical", "reductio", "analogical"]
    },
    "source_text_id": { "type": "string" },
    "tradition": { "type": "string" },
    "thinker": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "required": ["argument_id", "premises", "conclusion", "inference_type"]
}
