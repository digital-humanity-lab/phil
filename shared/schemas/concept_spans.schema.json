{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConceptSpans",
  "description": "GRanges-like concept annotations on philosophical texts.",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "text_id": { "type": "string" },
      "start": { "type": "integer", "minimum": 0 },
      "end": { "type": "integer", "minimum": 0 },
      "concept_id": { "type": "string", "pattern": "^phil:C[0-9]+$" },
      "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
      "annotator": { "type": "string", "description": "human:name or model:name" },
      "interpretation_id": { "type": "string" }
    },
    "required": ["text_id", "start", "end", "concept_id"]
  }
}
