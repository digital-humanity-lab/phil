    <node id="concept:basho">
      <data key="d0">Basho (Place)</data>
      <data key="d1">Concept</data>
      <data key="d2">場所</data>
      <data key="d8">Nishida's concept of 'place' as the self-determining locus of experience. The ultimate basho is absolute nothingness.</data>
    </node>
    <node id="concept:zettai-mu">
      <data key="d0">Absolute Nothingness</data>
      <data key="d1">Concept</data>
      <data key="d2">絶対無</data>
      <data key="d8">The ultimate place that envelops all being without itself being determined. The ground prior to subject-object division.</data>
    </node>
    <node id="concept:aidagara">
      <data key="d0">Aidagara (Betweenness)</data>
      <data key="d1">Concept</data>
      <data key="d2">間柄</data>
      <data key="d8">The relational space between persons that constitutes their individuality.</data>
    </node>
    <node id="concept:fudo">
      <data key="d0">Fudo (Climate/Milieu)</data>
      <data key="d1">Concept</data>
      <data key="d2">風土</data>
      <data key="d8">The climatic and cultural milieu that shapes human self-understanding. Not mere environment but the lived space of human existence.</data>
    </node>
    <node id="concept:sunyata">
      <data key="d0">Sunyata (Emptiness)</data>
      <data key="d1">Concept</data>
      <data key="d4">śūnyatā</data>
      <data key="d2">空</data>
      <data key="d7">空</data>
      <data key="d8">The emptiness of inherent existence. All phenomena arise dependently and lack self-nature.</data>
    </node>
    <node id="concept:dasein">
      <data key="d0">Dasein</data>
      <data key="d1">Concept</data>
      <data key="d3">Dasein</data>
      <data key="d2">現存在</data>
      <data key="d8">The being that understands Being. Human existence as being-in-the-world.</data>
    </node>
    <node id="concept:lichtung">
      <data key="d0">Lichtung (Clearing)</data>
      <data key="d1">Concept</data>
      <data key="d3">Lichtung</data>
      <data key="d2">開け</data>
      <data key="d8">The open region in which beings can show themselves and withdraw.</data>
    </node>
